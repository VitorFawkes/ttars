# =============================================================================
# WelcomeCRM — modelo de variáveis de ambiente
# =============================================================================
# Copie este arquivo para `.env` e preencha os valores.
#   cp .env.example .env
#
# IMPORTANTE:
# - NUNCA commite o `.env` (já está no .gitignore).
# - Os valores reais são entregues por canal seguro (1Password/Bitwarden), nunca por email/chat.
# - Onde o provedor permite token POR PESSOA (Supabase Access Token, Vercel Token),
#   gere o SEU próprio com o mesmo escopo — assim seu acesso é revogável sem afetar ninguém.
# - O dev local lê estas variáveis. Por padrão, VITE_SUPABASE_URL aponta para PRODUÇÃO.
#   Para testar contra STAGING, use o arquivo `.env.development.staging` (ver DEVELOPER_SETUP.md).
# =============================================================================

# --- Frontend (expostas ao navegador — protegidas por RLS) -------------------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_SENTRY_DSN=
VITE_VAPID_PUBLIC_KEY=
# Opcionais (têm default no código):
VITE_APP_ENV=development
# VITE_APP_VERSION=        # normalmente derivada no build
# VITE_FEEDBACK_WEBHOOK_URL=

# --- Supabase PRODUÇÃO (segredos — nunca expor) ------------------------------
# Acesso administrativo ao banco e à CLI. Gere SEU access token pessoal em
# https://supabase.com/dashboard/account/tokens (mesmo escopo do Vitor).
SUPABASE_ACCESS_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=
VAPID_PRIVATE_KEY=

# --- Supabase STAGING (para testar migrations antes de produção) -------------
STAGING_SUPABASE_URL=https://<staging-ref>.supabase.co
STAGING_SUPABASE_ANON_KEY=
STAGING_SERVICE_ROLE_KEY=
STAGING_ACCESS_TOKEN=
STAGING_PROJECT_REF=

# --- Deploy (Vercel) ---------------------------------------------------------
# Gere SEU próprio token em https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# --- Integrações -------------------------------------------------------------
N8N_API_KEY=
MONDE_V2_LOGIN=
MONDE_V2_PASSWORD=
ITERPEC_USERNAME=
ITERPEC_PASSWORD=
